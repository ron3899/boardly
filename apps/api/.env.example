# Database configuration
# For local development: postgresql://user:password@localhost:5432/boardly
# For production: postgresql://user:password@host:5432/boardly?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/boardly"

# JWT Secret - MUST be changed to a random string in production
JWT_SECRET="change-me-to-a-random-secret"

# Server port
PORT=3001

# CORS Origins - comma-separated list of allowed origins
# For local development: http://localhost:3000
# For production: https://your-app.vercel.app
# Multiple origins: http://localhost:3000,https://your-app.vercel.app
CORS_ORIGIN="http://localhost:3000"
